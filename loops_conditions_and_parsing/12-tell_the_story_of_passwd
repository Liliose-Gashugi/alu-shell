#!/usr/bin/env bash
# This script tells a story based on the /etc/passwd file using while loop and IFS
while IFS=: read -r username passwd uid gid info home shell
do
	echo "The user $username is part of the $gid gang, lives in $home and rides $shell. $uid's place is protected by the passcode $passwd, more info about the user here: $info"
done < /etc/passwd
